# Telegram bot token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Optional: custom yt-dlp executable path (Linux/macOS)
# YTDLP_PATH=yt-dlp

# Optional: JavaScript runtime list for yt-dlp (recommended for YouTube)
# YTDLP_JS_RUNTIMES=node

# Optional max download size in MB
# MAX_DOWNLOAD_MB=200

# Optional auto-download behavior
# AUTO_DOWNLOAD=true
