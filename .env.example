# Telegram bot token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Optional: standard production runtime mode
NODE_ENV=production

# Optional: maximum file size the bot will attempt to send to Telegram, in MB
MAX_DOWNLOAD_MB=200

# Optional: automatically download the default HD option when available
AUTO_DOWNLOAD=true

# Optional: custom yt-dlp executable path
# Linux/Docker usually does not need this because the image installs yt-dlp in PATH.
# Windows native hosting can point this at a local yt-dlp.exe if it is not in the project root.
# YTDLP_PATH=yt-dlp

# Optional: directory containing ffmpeg and ffprobe
# FFMPEG_LOCATION=C:\ffmpeg\bin

# Optional: JavaScript runtime list for yt-dlp (recommended for YouTube)
# YTDLP_JS_RUNTIMES=node

# Optional: proxy for yt-dlp (useful if cloud IP is blocked by YouTube)
# YTDLP_PROXY=http://user:pass@host:port

# Optional: let yt-dlp read cookies from an installed browser on native hosts
# This is usually not practical inside containers.
# COOKIES_FROM_BROWSER=chrome
