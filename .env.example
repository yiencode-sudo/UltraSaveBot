# Telegram bot token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Optional: custom yt-dlp executable path
# Windows example:
# YTDLP_PATH=D:\\botDownload\\yt-dlp.exe
# Linux/macOS example:
# YTDLP_PATH=yt-dlp

# Optional: directory containing ffmpeg and ffprobe
# Example:
# FFMPEG_LOCATION=C:\\ffmpeg\\bin

# Optional: browser cookies source for private/login-required media
# Example values: chrome, edge, firefox
# COOKIES_FROM_BROWSER=chrome
